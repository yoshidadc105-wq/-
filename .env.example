# ===== テスト時は TEST 用 LINE チャンネルの値を入れる =====
# ===== 本番移行時は本番の値に差し替える =================

# LINE Messaging API チャンネルシークレット
LINE_CHANNEL_SECRET=ここにChannel_Secretを貼る

# LINE Messaging API チャンネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=ここにAccess_Tokenを貼る

# Stransa の Webhook URL（本番移行時のみ設定。テスト時は空でOK）
STRANSA_WEBHOOK_URL=https://line-backend.stransa.co.jp/v1/line-message/70f88cc018f36a290eb74daec8905e55

# Google Forms などの問診表URL
QUESTIONNAIRE_URL=ここに問診表のURLを貼る

# テストモード: true にすると Stransa への転送をスキップする
TEST_MODE=true

# サーバーポート（Renderなどは自動設定されるため通常変更不要）
PORT=3000
